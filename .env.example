# Telegram Bridge Environment Variables
# Copy this to .env.local and fill in your values

# Base URL of your deployed app (without trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Bot username (without @) for Telegram Login widget
# Can be the same bot you'll use for bridging, or any bot you created
NEXT_PUBLIC_TELEGRAM_BOT_ID=your_bot_username

# Auth callback URL (usually same as BASE_URL)
NEXT_PUBLIC_AUTH_CALLBACK_URL=https://your-domain.vercel.app

# Default message limit per chat
DEFAULT_MESSAGE_LIMIT=100

# Neon / Postgres connection string
# Use either DATABASE_URL or POSTGRES_URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Web Push VAPID keys
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_vapid_key
VAPID_PRIVATE_KEY=your_private_vapid_key
